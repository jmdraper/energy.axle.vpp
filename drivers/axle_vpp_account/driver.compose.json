{
  "id": "axle_vpp_account",
  "name": { "en": "Axle VPP Account" },
  "class": "other",
  "capabilities": [
    "alarm_generic",
    "axle_event_state",
    "axle_minutes_to_start",
    "axle_minutes_remaining",
    "axle_earnings_month"
  ],
  "capabilitiesOptions": {
    "alarm_generic": {
      "title": { "en": "Grid Event Active" }
    }
  },
  "platforms": ["local"],
  "connectivity": ["cloud"],
  "images": {
    "small":  "./drivers/axle_vpp_account/assets/images/small.png",
    "large":  "./drivers/axle_vpp_account/assets/images/large.png",
    "xlarge": "./drivers/axle_vpp_account/assets/images/xlarge.png"
  },
  "pair": [
    {
      "id": "login_credentials"
    }
  ],
  "repair": [
    {
      "id": "repair_credentials"
    }
  ],
  "settings": [
    {
      "id": "poll_interval_normal",
      "type": "number",
      "label": { "en": "Background poll interval (minutes)" },
      "value": 10,
      "attr": { "min": 5, "max": 60 },
      "hint": { "en": "How often to check the Axle API when no event is imminent." }
    },
    {
      "id": "poll_interval_active",
      "type": "number",
      "label": { "en": "Pre-event/active poll interval (seconds)" },
      "value": 60,
      "attr": { "min": 30, "max": 300 },
      "hint": { "en": "How often to poll during the 2 hours before and during an event." }
    },
    {
      "id": "pre_event_window_hours",
      "type": "number",
      "label": { "en": "Fast-poll window before event (hours)" },
      "value": 2,
      "attr": { "min": 1, "max": 6 },
      "hint": { "en": "How many hours before an event to switch to fast polling." }
    }
  ]
}
